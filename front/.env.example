# Turf Booking — frontend env
#
# Copy to `.env` (committed, dev defaults) or `.env.production` (deployed).
# Vite reads these at build/dev time and exposes variables prefixed with
# VITE_ on `import.meta.env`. The single value that matters is:
#
#   VITE_API_URL — origin of the backend (no trailing slash, no /api/v1)
#
# All API calls and image URLs are derived from this one variable. See
# `src/config/Api.jsx`.

# Local dev default
VITE_API_URL=http://localhost:5050

# Production example:
# VITE_API_URL=https://api.turfbook.com
