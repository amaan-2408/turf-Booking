# Turf Booking — backend env
#
# Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# .env is gitignored. Never commit real keys.

# HTTP port (optional — defaults to 5050)
PORT=5050

# MongoDB connection string. Local dev:
#   mongodb://127.0.0.1:27017/turf-booking
# Production (MongoDB Atlas):
#   mongodb+srv://USER:PASS@cluster.mongodb.net/turf-booking?retryWrites=true&w=majority
DB_URL=mongodb://127.0.0.1:27017/turf-booking

# JWT signing secret for auth tokens. Any long random string works in dev.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT: rotate if you ever suspect it leaked. Tokens are valid for 7d.
JWT_KEY=replace-with-a-long-random-string

# Stripe secret key. Optional at boot — the server starts fine without it,
# but /api/v1/payment/checkout will return 500 until this is set.
# Test mode keys start with sk_test_, live keys with sk_live_.
# Get one at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Used by the backend to verify that
# `checkout.session.completed` events actually came from Stripe.
# Dev: run `stripe listen --forward-to localhost:5050/api/v1/payment/webhook`
#      and copy the `whsec_...` value it prints.
# Prod: create a webhook endpoint in the Stripe dashboard pointing at
#       https://your-api-domain.com/api/v1/payment/webhook and copy its
#       signing secret.
# Optional in dev — without it the webhook will reject events with 400, but
# the frontend's /payment-success page still works via the finalize fallback.
STRIPE_WEBHOOK_SECRET=

# Where uploaded turf images land. Default "assets" is relative to cwd
# (fine for dev). In production set this to an absolute path on a
# persistent volume, e.g. /var/data/turf-booking/uploads
UPLOAD_DIR=assets

# Public origin where the frontend is hosted. Used by Stripe success/cancel
# redirects. Trailing slash optional. Example: https://turfbook.com
FRONTEND_URL=http://localhost:5174